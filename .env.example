# -------- required --------
# Claude API key (used for research briefs + draft generation + signal scoring)
ANTHROPIC_API_KEY=

# -------- recommended (all have free tiers) --------
# Exa — neural search + content fetch (1,000 req/mo free)
# https://exa.ai
EXA_API_KEY=

# Firecrawl — scrape company careers/about pages (500 free, 20,000 with .edu email)
# https://firecrawl.dev
FIRECRAWL_API_KEY=

# GitHub — org activity signals (5,000 req/hr authenticated, 60/hr unauthenticated)
# https://github.com/settings/tokens  (no scopes needed for public repo reads)
GITHUB_TOKEN=

# -------- optional (paid or niche) --------
# Apollo — contact enrichment + firmographics (you probably have this).
# Apollo's free tier quota is tight — contact enrichment is OFF by default
# even when the key is set. Flip APOLLO_ENABLED=1 (or set
# `apollo_enrichment: true` at the top level of your icp.yaml) to opt in.
APOLLO_API_KEY=
APOLLO_ENABLED=0

# Hunter.io — email finder fallback (25-50 free searches/mo)
HUNTER_API_KEY=

# FMP — already in your environment; used for public-company earnings signals
FMP_API_KEY=

# HubSpot private app token — route enriched accounts into CRM
HUBSPOT_TOKEN=

# Slack webhook — send high-priority signal alerts to a channel
SLACK_WEBHOOK_URL=

# -------- config --------
# Where the pipeline writes runs, cache, and sqlite DB (default: ./data)
SIGNALFORGE_DATA_DIR=./data
# Primary Claude model (default: claude-opus-4-7)
SIGNALFORGE_CLAUDE_MODEL=claude-opus-4-7
# Cheap Claude model for signal classification (default: claude-haiku-4-5-20251001)
SIGNALFORGE_CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
